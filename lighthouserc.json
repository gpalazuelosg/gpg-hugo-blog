{
  "ci": {
    "collect": {
      "url": ["http://localhost:8080/blog/fixture-post/"],
      "startServerCommand": "npx -y http-server src/site/public -p 8080 --silent",
      "startServerReadyPattern": "Available",
      "numberOfRuns": 3
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
